{
  "buildCommand": "npx prisma generate",
  "outputDirectory": "public",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/health", "destination": "/api" },
    { "source": "/swagger-ui.html", "destination": "/api" },
    { "source": "/v3/api-docs", "destination": "/api" }
  ]
}
