{
  "name": "saas-invoice-api",
  "version": "1.0.0",
  "description": "Node.js backend for SaaS Invoice API",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "npm run db:setup && node --watch index.js",
    "build": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:setup": "npx prisma db execute --file scripts/setup-tables.sql && node prisma/seed.js",
    "test": "jest --forceExit --detectOpenHandles"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16",
    "resend": "^6.18.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "prisma": "^7.9.0"
  }
}
