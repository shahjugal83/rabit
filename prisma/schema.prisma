generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  userId       String   @id @default(uuid()) @map("user_id")
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String?  @map("first_name")
  lastName     String?  @map("last_name")
  addressLine1 String?  @map("address_line1")
  addressLine2 String?  @map("address_line2")
  city         String?
  state        String?
  pinCode      String?  @map("pin_code")
  country      String?
  status       String   @default("INACTIVE")
  emailVerified Boolean @default(false) @map("email_verified")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  companyUsers       CompanyUser[]
  verificationTokens VerificationToken[]
  createdRoles       Role[]          @relation("createdRoles")
  updatedRoles       Role[]          @relation("updatedRoles")
  createdDocs        DocumentType[]  @relation("createdDocs")
  updatedDocs        DocumentType[]  @relation("updatedDocs")
  createdMaterials   Material[]      @relation("createdMaterials")
  updatedMaterials   Material[]      @relation("updatedMaterials")
  createdInvoices    Invoice[]       @relation("createdInvoices")

  @@map("users")
}

model Company {
  companyId     String   @id @default(uuid()) @map("company_id")
  name          String   @unique
  urlSlug       String   @unique @map("url_slug")
  description   String?
  addressLine1  String   @map("address_line1")
  addressLine2  String?  @map("address_line2")
  city          String
  state         String
  country       String
  pinCode       String   @map("pin_code")
  contactNumber String   @map("contact_number")
  logo          Bytes?
  createdBy     String?  @map("created_by")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  companyUsers  CompanyUser[]
  documentTypes DocumentType[]
  roles         Role[]
  featureMgt    FeatureMgt?
  materialCompanies MaterialCompany[]

  @@map("companies")
}

model Role {
  roleId        String   @id @default(uuid()) @map("role_id")
  name          String
  description   String?
  isSystem      Boolean  @default(false) @map("is_system")
  companyId     String?  @map("company_id")
  createdBy     String?  @map("created_by")
  updatedBy     String?  @map("updated_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  company         Company?         @relation(fields: [companyId], references: [companyId])
  creator         User?            @relation("createdRoles", fields: [createdBy], references: [userId])
  updater         User?            @relation("updatedRoles", fields: [updatedBy], references: [userId])
  rolePermissions RolePermission[]
  companyUsers    CompanyUser[]

  @@unique([companyId, name])
  @@map("roles")
}

model Permission {
  permissionId String   @id @default(uuid()) @map("permission_id")
  resource     String
  action       String
  description  String?
  createdAt    DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [roleId], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [permissionId], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model CompanyUser {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  companyId String   @map("company_id")
  roleId    String   @map("role_id")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [userId])
  company Company @relation(fields: [companyId], references: [companyId])
  role    Role    @relation(fields: [roleId], references: [roleId])

  @@unique([userId, companyId])
  @@map("company_users")
}

model VerificationToken {
  tokenId    String   @id @default(uuid()) @map("token_id")
  userId     String   @map("user_id")
  token      String   @unique
  tokenType  String   @map("token_type")
  status     String
  expiryAt   DateTime @map("expiry_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [userId])

  @@index([token])
  @@index([userId])
  @@index([expiryAt])
  @@map("verification_tokens")
}

model DocumentType {
  documentTypeId String   @id @default(uuid()) @map("document_type_id")
  companyId      String   @map("company_id")
  name           String
  documentNumber String?  @map("document_number")
  createdBy      String?  @map("created_by")
  updatedBy      String?  @map("updated_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [companyId])
  creator User?   @relation("createdDocs", fields: [createdBy], references: [userId])
  updater User?   @relation("updatedDocs", fields: [updatedBy], references: [userId])

  @@unique([companyId, name])
  @@map("document_types")
}

model FeatureMgt {
  id                    String   @id @default(uuid())
  companyId             String   @unique @map("company_id")
  userFeature           Boolean  @default(false) @map("user_feature")
  isInvoiceManagement   Boolean  @default(false) @map("is_invoice_management")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [companyId])

  @@map("feature_mgt")
}

model Material {
  materialId   String   @id @default(uuid()) @map("material_id")
  materialName String   @map("material_name")
  createdBy    String?  @map("created_by")
  updatedBy    String?  @map("updated_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  creator        User?              @relation("createdMaterials", fields: [createdBy], references: [userId])
  updater        User?              @relation("updatedMaterials", fields: [updatedBy], references: [userId])
  companies      MaterialCompany[]
  identifiers    MaterialIdentifier[]

  @@unique([materialName])
  @@map("materials")
}

model MaterialCompany {
  id        String   @id @default(uuid())
  materialId String  @map("material_id")
  companyId String  @map("company_id")
  createdAt DateTime @default(now()) @map("created_at")

  material Material @relation(fields: [materialId], references: [materialId], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [companyId], onDelete: Cascade)

  @@unique([materialId, companyId])
  @@map("material_companies")
}

model MaterialIdentifier {
  identifierId   String   @id @default(uuid()) @map("identifier_id")
  materialId     String   @map("material_id")
  identifierName String   @map("identifier_name")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  material Material @relation(fields: [materialId], references: [materialId], onDelete: Cascade)

  @@unique([materialId, identifierName])
  @@map("material_identifiers")
}

model Invoice {
  invoiceId      Int      @id @default(autoincrement()) @map("invoice_id")
  documentNumber String   @map("document_number")
  documentName   String   @map("document_name")
  companyName    String   @map("company_name")
  createdBy      String?  @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")

  creator User?             @relation("createdInvoices", fields: [createdBy], references: [userId])
  items   InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  itemId         Int    @id @default(autoincrement()) @map("item_id")
  invoiceId      Int    @map("invoice_id")
  materialName   String @map("material_name")
  identifierName String @map("identifier_name")

  invoice Invoice @relation(fields: [invoiceId], references: [invoiceId], onDelete: Cascade)

  @@map("invoice_items")
}
